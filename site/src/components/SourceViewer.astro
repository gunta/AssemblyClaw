<div class="source-overlay" id="source-overlay">
  <div class="source-modal">
    <div class="source-header">
      <div class="source-header-left">
        <span class="source-filename" id="source-filename"></span>
        <span class="source-lines" id="source-lines"></span>
      </div>
      <button class="source-close" id="source-close" aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="source-body">
      <pre class="source-pre"><code id="source-code"></code></pre>
    </div>
  </div>
</div>
