---
import type { Lang } from '../i18n';
import { t } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div
  class="source-overlay"
  id="source-overlay"
  role="dialog"
  aria-modal="true"
  aria-labelledby="source-filename"
  aria-describedby="source-meta"
>
  <div class="source-modal">
    <div class="source-header">
      <div class="source-header-left">
        <span class="source-filename" id="source-filename"></span>
        <span class="source-lines" id="source-meta"></span>
      </div>
      <div class="source-header-actions">
        <button class="source-action" id="source-copy" type="button">
          {t(lang, 'source.modal.copy')}
        </button>
        <a class="source-action" id="source-download" download>
          {t(lang, 'source.modal.download')}
        </a>
        <a class="source-action" id="source-raw" target="_blank" rel="noopener">
          {t(lang, 'source.modal.raw')}
        </a>
        <a class="source-action" id="source-github" target="_blank" rel="noopener">
          {t(lang, 'source.modal.github')}
        </a>
      </div>
      <button class="source-close" id="source-close" aria-label={t(lang, 'source.modal.close')}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="source-body">
      <pre class="source-pre"><code id="source-code"></code></pre>
    </div>
  </div>
</div>
