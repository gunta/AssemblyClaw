---
import type { Lang } from '../i18n';
import { t } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const features = [
  { icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/><path d="M8 4v3M16 4v3M8 10v3M16 10v3M8 16v4M16 16v4" stroke-width="1" opacity=".5"/></svg>', titleKey: 'arch.neon.title', descKey: 'arch.neon.desc' },
  { icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/></svg>', titleKey: 'arch.cache.title', descKey: 'arch.cache.desc' },
  { icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 12h16M20 12l-4-4M20 12l-4 4"/></svg>', titleKey: 'arch.branchless.title', descKey: 'arch.branchless.desc' },
  { icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18M15 3v18"/></svg>', titleKey: 'arch.arena.title', descKey: 'arch.arena.desc' },
  { icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 8h10M4 12h16M4 16h12"/><circle cx="18" cy="8" r="2" stroke-width="1" opacity=".5"/><circle cx="20" cy="16" r="2" stroke-width="1" opacity=".5"/></svg>', titleKey: 'arch.zerocopy.title', descKey: 'arch.zerocopy.desc' },
  { icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 3v7M12 14v7"/><circle cx="12" cy="12" r="3"/><path d="M5 12H9M15 12h4"/></svg>', titleKey: 'arch.libsystem.title', descKey: 'arch.libsystem.desc' },
  { icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M4 12h16"/><path d="M8 4v16" opacity=".4"/><path d="M12 4v16"/><path d="M16 4v16" opacity=".4"/></svg>', titleKey: 'arch.register.title', descKey: 'arch.register.desc' },
  { icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M9 3H5a2 2 0 00-2 2v4"/><path d="M15 3h4a2 2 0 012 2v4"/><path d="M9 21H5a2 2 0 01-2-2v-4"/><path d="M15 21h4a2 2 0 002-2v-4"/><rect x="8" y="8" width="8" height="8" rx="1" fill="currentColor" opacity=".15"/><path d="M8 12h8M12 8v8" opacity=".5"/></svg>', titleKey: 'arch.isa.title', descKey: 'arch.isa.desc' },
];

const files = [
  { file: 'main.s', key: 'arch.file.main' },
  { file: 'string.s', key: 'arch.file.string' },
  { file: 'memory.s', key: 'arch.file.memory' },
  { file: 'io.s', key: 'arch.file.io' },
  { file: 'json.s', key: 'arch.file.json' },
  { file: 'http.s', key: 'arch.file.http' },
  { file: 'config.s', key: 'arch.file.config' },
  { file: 'provider.s', key: 'arch.file.provider' },
  { file: 'agent.s', key: 'arch.file.agent' },
  { file: 'error.s', key: 'arch.file.error' },
  { file: 'varargs.s', key: 'arch.file.varargs' },
  { file: 'version.s', key: 'arch.file.version' },
];

const includeFiles = [
  { file: 'constants.inc', key: 'arch.file.constants' },
  { file: 'syscall.inc', key: 'arch.file.syscall' },
];
---

<section class="architecture" id="architecture">
  <div class="section-container">
    <div class="section-eyebrow reveal">{t(lang, 'arch.eyebrow')}</div>
    <h2 class="section-title reveal" set:html={t(lang, 'arch.title')} />
    <p class="section-description reveal" set:html={t(lang, 'arch.description')} />

    <div class="arch-grid">
      <div class="arch-features">
        {features.map(({ icon, titleKey, descKey }) => (
          <div class="arch-feature reveal">
            <div class="arch-feature-icon" set:html={icon} />
            <h4 set:html={t(lang, titleKey)} />
            <p set:html={t(lang, descKey)} />
          </div>
        ))}
      </div>

      <div class="arch-files reveal">
        <div class="file-tree">
          <div class="file-tree-header">
            <span class="file-tree-folder">src/</span>
          </div>
          {files.map(({ file, key }) => (
            <div class="file-entry" data-file={file}>
              <span class="file-name">{file}</span>
              <span class="file-desc">{t(lang, key)}</span>
            </div>
          ))}
          <div class="file-tree-header file-tree-header--sub">
            <span class="file-tree-folder">include/</span>
          </div>
          {includeFiles.map(({ file, key }) => (
            <div class="file-entry" data-file={file}>
              <span class="file-name">{file}</span>
              <span class="file-desc">{t(lang, key)}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
