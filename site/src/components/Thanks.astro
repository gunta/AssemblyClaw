---
import type { Lang } from '../i18n';
import { t } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="thanks">
  <div class="section-container">
    <div class="thanks-card reveal">
      <div class="thanks-icon"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg></div>
      <h3 class="thanks-title">{t(lang, 'thanks.title')}</h3>
      <p class="thanks-text" set:html={t(lang, 'thanks.text')} />
      <p class="thanks-disclaimer" set:html={t(lang, 'thanks.disclaimer')} />
    </div>
  </div>
</section>
