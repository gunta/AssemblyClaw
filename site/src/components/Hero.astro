---
import type { Lang } from '../i18n';
import { t } from '../i18n';
import { repoData, defaultSourceFile } from '../generated/repo-data';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const featuredFile = defaultSourceFile;
---

<section class="hero" id="hero">
  <canvas id="hero-canvas" aria-hidden="true"></canvas>
  <div class="hero-halftone hero-halftone--left"></div>
  <div class="hero-halftone hero-halftone--right"></div>
  <div class="hero-grid-lines"></div>

  <div class="hero-content">
    <div class="hero-badge reveal">
      <span class="badge-dot"></span>
      <span>{t(lang, 'hero.badge')}</span>
      <span class="hero-badge-sep">•</span>
      <span>{repoData.versionTag}</span>
    </div>
    <h1 class="hero-title reveal">
      <span class="hero-line">{t(lang, 'hero.title.line1')}</span>
      <span class="hero-line hero-line--accent">{t(lang, 'hero.title.line2')}</span>
      <span class="hero-line">{t(lang, 'hero.title.line3')}</span>
    </h1>
    <p class="hero-sub reveal" set:html={t(lang, 'hero.sub')} />

    <div class="hero-stats reveal">
      <div class="stat">
        <span class="stat-value" id="bench-hero-binary">35</span>
        <span class="stat-unit">KB</span>
        <span class="stat-label">{t(lang, 'hero.stat.binary')}</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value" id="bench-hero-startup">4</span>
        <span class="stat-unit">ms</span>
        <span class="stat-label">{t(lang, 'hero.stat.startup')}</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value" id="bench-hero-ram">1312</span>
        <span class="stat-unit">KB</span>
        <span class="stat-label">{t(lang, 'hero.stat.ram')}</span>
      </div>
    </div>

    <div class="hero-actions reveal">
      <a href="#source" class="btn btn--primary" data-source-open={featuredFile?.file}>
        <span>{t(lang, 'hero.cta.source')}</span>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="#install" class="btn btn--ghost">
        <span>{t(lang, 'hero.cta.start')}</span>
      </a>
    </div>
  </div>

  <div class="hero-scroll-hint">
    <span>{t(lang, 'hero.scroll')}</span>
    <div class="scroll-line"></div>
  </div>
</section>
