---
import type { Lang } from '../i18n';
import { t, getLocalizedPath, getAlternateLang } from '../i18n';
import '../styles/style.css';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const base = import.meta.env.BASE_URL;
const altLang = getAlternateLang(lang);
const canonicalPath = getLocalizedPath(lang, base);
const altPath = getLocalizedPath(altLang, base);
const site = import.meta.env.SITE ?? '';
---

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{t(lang, 'meta.title')}</title>
  <meta name="description" content={t(lang, 'meta.description')}>
  <meta property="og:title" content={t(lang, 'meta.ogTitle')}>
  <meta property="og:description" content={t(lang, 'meta.ogDescription')}>
  <meta property="og:type" content="website">
  <link rel="canonical" href={`${site}${canonicalPath}`}>
  <link rel="alternate" hreflang={lang} href={`${site}${canonicalPath}`}>
  <link rel="alternate" hreflang={altLang} href={`${site}${altPath}`}>
  <link rel="alternate" hreflang="x-default" href={`${site}${getLocalizedPath('en', base)}`}>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🦀</text></svg>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&family=Outfit:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
