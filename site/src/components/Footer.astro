---
import type { Lang } from '../i18n';
import { t } from '../i18n';
import { repoData } from '../generated/repo-data';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="footer">
  <div class="footer-halftone"></div>
  <div class="section-container">
    <div class="footer-inner">
      <div class="footer-left">
        <span class="footer-logo">⌘ AssemblyClaw</span>
        <span class="footer-license">{t(lang, 'footer.license')}</span>
      </div>
      <div class="footer-right">
        <a href={repoData.repoUrl} target="_blank" rel="noopener">GitHub</a>
        <a href="https://x.com/gunta85" target="_blank" rel="noopener">@gunta85</a>
        <a href="https://guntherbrunner.com" target="_blank" rel="noopener">guntherbrunner.com</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>{t(lang, 'footer.bottom')}</p>
    </div>
  </div>
</footer>
